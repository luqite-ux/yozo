{
  "name": "enterprise-sanity-site-template",
  "private": true,
  "description": "外贸企业官网模板：website（Vite）+ studio（Sanity）",
  "scripts": {
    "dev": "npm run dev --prefix website",
    "dev:website": "npm run dev --prefix website",
    "dev:studio": "npm run dev --prefix studio",
    "build:website": "npm run build --prefix website",
    "build:studio": "npm run build --prefix studio",
    "lint:website": "npm run lint --prefix website",
    "validate:studio": "npm run validate --prefix studio",
    "seed:studio": "npm run seed:defaults --prefix studio",
    "verify:read": "node website/scripts/verify-sanity-read.mjs"
  }
}
