                </div>
                <div className="flex justify-between mt-4 text-[10px] text-slate-500 font-bold uppercase tracking-widest border-t border-white/5 pt-4">
                   <span>00:00</span>
                   <span>06:00</span>
                   <span>12:00</span>
                   <span>18:00</span>
                   <span>24:00</span>
