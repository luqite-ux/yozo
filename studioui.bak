            <div className="lg:col-span-2 relative overflow-hidden bg-slate-900 rounded-[2.5rem] p-10 text-white shadow-2xl">
              <div className="relative z-10">
                <div className="flex items-center space-x-3 mb-4">
                   <span className="px-3 py-1 bg-blue-500 rounded-full text-[10px] font-bold tracking-tighter uppercase">Live Traffic</span>
                   <span className="text-slate-400 text-xs font-medium">最近24小时全球流量概况</span>
                </div>
                <h1 className="text-3xl font-black mb-6 leading-tight">{greeting}，您的业务正在稳步增长。</h1>
                
                {/* 流量走势模拟 */}
                <div className="mt-8 flex items-end space-x-2 h-40">
                   {[30, 45, 35, 60, 40, 75, 50, 90, 65, 100, 80, 55, 70, 85, 40, 60, 95, 75].map((h, i) => (
                     <div key={i} className="flex-1 group relative">
                        <div className="bg-gradient-to-t from-blue-600 to-cyan-400 rounded-t-lg opacity-40 group-hover:opacity-100 transition-opacity" style={{height: `${h}%`}}></div>
                        <div className="absolute -top-8 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 bg-white text-slate-900 text-[10px] font-bold px-1.5 py-0.5 rounded transition-opacity shadow-lg">
                           {h}k
                        </div>
