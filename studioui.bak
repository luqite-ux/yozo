                    { title: 'CRM 核心客户回访', time: '16:30', icon: Users, color: 'text-emerald-500' },
                    { title: '导出流量周报', time: '18:00', icon: BarChart3, color: 'text-blue-500' },
                  ].map((task, i) => (
