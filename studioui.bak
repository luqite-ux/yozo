                        <Languages size={20} className="mb-2 group-hover:scale-110 transition-transform" />
                        <span className="text-[10px] font-bold">一键翻译</span>
                     </button>
                  </div>
                </div>
              </div>

              <div className="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm p-8">
