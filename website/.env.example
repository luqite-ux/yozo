# —— 浏览器可读（VITE_ 会打进前端，仅用于 CDN 读已发布内容）——
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01
VITE_SANITY_USE_CDN=true

# 可选：只读 token（一般公开站不需要）
# VITE_SANITY_READ_TOKEN=

# —— 仅服务端 / 构建环境（切勿使用 VITE_ 前缀；勿提交含真实 token 的 .env）——
# 询盘 API（Vite 开发中间件 + Vercel Serverless）写入 Sanity 时使用：
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
# 在 https://sanity.io/manage 创建具有 Document create 权限的 token（建议仅授予 inquiry 或最小权限）
# 严禁为写入 token 加 VITE_ 前缀（否则会打进前端包，造成泄露）
SANITY_API_WRITE_TOKEN=
