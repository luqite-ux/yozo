import React, { useState, useEffect } from 'react';
import { 
  LayoutDashboard, 
  Package, 
  Layers, 
  FileText, 
  HelpCircle, 
  Briefcase, 
  MessageSquare, 
  Bell, 
  Settings, 
  Search, 
  User, 
  ChevronRight, 
  Plus, 
  TrendingUp, 
  ExternalLink,
  Globe,
  Image as ImageIcon,
  MoreVertical,
  LogOut,
  Menu,
  X,
  Users,
  BarChart3,
  Languages,
  CheckCircle2,
  Clock
} from 'lucide-react';

// 模拟数据
const stats = [
  { id: 1, name: '产品总数', value: '1,284', change: '+12%', icon: Package, color: 'from-blue-500 to-cyan-400' },
  { id: 2, name: '文章发布', value: '456', change: '+5%', icon: FileText, color: 'from-purple-500 to-indigo-400' },
  { id: 3, name: 'CRM 客户数', value: '2,840', change: '+24%', icon: Users, color: 'from-emerald-500 to-teal-400' },
  { id: 4, name: '案例展示', value: '89', change: '+2%', icon: Briefcase, color: 'from-amber-500 to-orange-400' },
];

const inquiries = [
  { id: 1, name: '陈先生', email: 'chen@example.com', subject: '产品报价咨询', time: '10分钟前', status: '待处理', priority: '高' },
  { id: 2, name: '张经理', email: 'zhang_pro@company.com', subject: '长期合作意向', time: '2小时前', status: '已跟进', priority: '中' },
  { id: 3, name: 'Roberts', email: 'rob@global.net', subject: '定制需求咨询', time: '5小时前', status: '待处理', priority: '高' },
];

const crmCustomers = [
  { id: 1, name: 'Global Trade Inc.', level: 'VIP', lastContact: '3小时前', value: '￥12.5k' },
  { id: 2, name: '美妆连锁采购部', level: '核心', lastContact: '1天前', value: '￥45.0k' },
  { id: 3, name: '欧洲代理商 Leon', level: '潜在', lastContact: '2天前', value: '￥8.2k' },
];

const App = () => {
  const [isSidebarOpen, setSidebarOpen] = useState(true);
  const [activeTab, setActiveTab] = useState('dashboard');
  const [greeting, setGreeting] = useState('');
  const [translationActive, setTranslationActive] = useState(true);

  useEffect(() => {
    const hour = new Date().getHours();
    if (hour < 12) setGreeting('早上好');
    else if (hour < 18) setGreeting('下午好');
    else setGreeting('晚上好');
  }, []);

  const NavItem = ({ id, label, icon: Icon, badge }) => (
    <button
      onClick={() => setActiveTab(id)}
      className={`w-full flex items-center justify-between px-4 py-3 rounded-xl transition-all duration-200 ${
        activeTab === id 
        ? 'bg-gradient-to-r from-blue-600 to-indigo-600 text-white shadow-lg shadow-blue-200' 
        : 'text-slate-500 hover:bg-slate-100 hover:text-slate-900'
      }`}
    >
      <div className="flex items-center space-x-3">
        <Icon size={20} />
        <span className={`font-medium ${!isSidebarOpen && 'hidden'}`}>{label}</span>
      </div>
      {badge && isSidebarOpen && (
        <span className={`text-[10px] px-1.5 py-0.5 rounded-md font-bold ${activeTab === id ? 'bg-white/20 text-white' : 'bg-rose-100 text-rose-600'}`}>
          {badge}
        </span>
      )}
