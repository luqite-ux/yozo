# 复制为 .env（或填到 Vercel 环境变量）；projectId 勿提交进 Git。
# 必填项：在下一行填入 sanity.io/manage 里项目的 Project ID。
# Vercel（Studio 项目）：变量名必须是 SANITY_STUDIO_PROJECT_ID，不能写成 SANITY_PROJECT_ID / VITE_*。
# 若 CI 仍未注入变量，可在 sanity.project.constants.js 中设置 STUDIO_PROJECT_ID_FALLBACK（id 可公开）。

SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# 可选：品牌化（顶栏；不填则用 sanity.config.js / StudioBrandLogo 默认文案）
# SANITY_STUDIO_BRAND_TITLE=Huanqiu · 外贸企业官网后台模板
# SANITY_STUDIO_BRAND_SHORT=Huanqiu
# 一次性导入前台默认文案到 Sanity（需写权限，可与 website 共用）：
# SANITY_API_WRITE_TOKEN=
#
# DeepSeek（翻译 Webhook / Studio 预翻译脚本；也可只写在 webhook/.env）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# SANITY_STUDIO_LOGO_URL=https://your-cdn.com/studio-logo.svg
#
# ── Studio「同步翻译」/ 发布后自动翻译：POST 的目标 URL（你部署的 Node webhook，不是 api.deepseek.com）──
# 路径必须是 /webhook/translate（与 webhook/server.js 一致）。
# 本地：先 npm run dev --prefix webhook，再填：
# SANITY_STUDIO_TRANSLATION_WEBHOOK_URL=http://127.0.0.1:3001/webhook/translate
# 生产示例（Railway/Render/Fly 等）：
# SANITY_STUDIO_TRANSLATION_WEBHOOK_URL=https://your-translation-service.example.com/webhook/translate
# 若 webhook 启用了 SANITY_WEBHOOK_SECRET，须与 webhook 环境配置相同的绕过密钥（仅 Studio 浏览器请求用）：
# SANITY_STUDIO_TRANSLATE_BYPASS_KEY=
#
# 若 Studio 不是 localhost:3333 打开（如局域网 IP），须在 webhook 侧配置 SANITY_STUDIO_TRANSLATE_CORS_ORIGINS（见 webhook/.env.example）。
