# 翻译 Webhook 服务环境变量
# 复制为 .env 并填写，不要提交 .env 到 Git

# Sanity 项目信息（与 studio/.env.local 相同）
SANITY_PROJECT_ID=your_project_id_here
SANITY_DATASET=production

# Sanity 写权限 token（直接复制 website/.env.local 里的 SANITY_API_WRITE_TOKEN 值）
SANITY_WRITE_TOKEN=

# Webhook 签名密钥（在 Sanity 后台配置 Webhook 时生成，复制过来）
SANITY_WEBHOOK_SECRET=

# MyMemory 翻译 API（可选）
# 填写邮箱后每日免费额度从 5000 字提升到 50000 字
MYMEMORY_EMAIL=

# 服务端口（默认 3001）
PORT=3001
