          <NavItem id="analytics" label="流量分析" icon={BarChart3} />
          <NavItem id="inquiry" label="客户询盘" icon={MessageSquare} badge="3" />
          
          <div className={`px-4 mt-8 mb-2 text-xs font-semibold text-slate-400 uppercase tracking-wider ${!isSidebarOpen && 'hidden'}`}>
